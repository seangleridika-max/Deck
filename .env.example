# 环境变量配置示例

# ========== 前端配置 ==========
# Gemini API密钥
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Worker API地址
VITE_API_URL=http://localhost:8787

# Sentry DSN（可选）
VITE_SENTRY_DSN=

# 环境标识
VITE_ENV=development

# ========== Worker配置 ==========
# Fabric认证Token
FABRIC_TOKEN=your_secure_random_token_here

# 最大上传大小（MB）
FABRIC_MAX_UPLOAD_MB=100

# Gemini API密钥（Worker侧）
GEMINI_API_KEY=your_gemini_api_key_here

# ========== 开发工具配置 ==========
# GitHub Personal Access Token（用于AO）
GH_PAT=

# Composio AO Webhook
AO_WEBHOOK_URL=

# Slack Webhook（用于通知）
SLACK_WEBHOOK=
